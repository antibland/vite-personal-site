{
  "name": "vite-personal-site",
  "private": false,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.13.1"
  },
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "vite",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "node scripts/generate-sitemap.mjs && tsc && vite build && node scripts/generate-extensionless-html.mjs && node scripts/generate-404-html.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "serve dist",
    "lighthouse": "node scripts/lighthouse-preview.mjs",
    "lighthouse:desktop": "node scripts/lighthouse-preview.mjs --preset=desktop",
    "lighthouse:view": "node scripts/lighthouse-preview.mjs --view --output=html --output-path=./lighthouse-report.html"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@unhead/react": "^3.1.4",
    "prism-themes": "^1.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "rehype-prism-plus": "^2.0.2",
    "simple-icons": "^16.19.0",
    "vite-plugin-markdown": "^2.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@mdx-js/rollup": "^3.1.1",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lighthouse": "^12.8.2",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "serve": "^14.2.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-react-ssg": "^0.2.0"
  }
}
